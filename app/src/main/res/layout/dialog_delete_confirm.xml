<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog"
    android:paddingHorizontal="24dp"
    android:paddingTop="28dp"
    android:paddingBottom="24dp">

    <!-- Icon lingkaran merah + trash -->
    <FrameLayout
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_icon_circle_red_light">

        <ImageView
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_delete"
            app:tint="#EF4444"
            android:contentDescription="@null" />

    </FrameLayout>

    <!-- Judul -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="16dp"
        android:text="Hapus Pengajuan?"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E" />

    <!-- Subjudul -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="24dp"
        android:text="Data yang dihapus tidak dapat\ndikembalikan kembali."
        android:textSize="13sp"
        android:textColor="#64748B"
        android:gravity="center" />

    <!-- Garis pemisah -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F1F5F9"
        android:layout_marginBottom="16dp" />

    <!-- Tombol aksi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Tombol Batal -->
        <Button
            android:id="@+id/btnDialogBatal"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:backgroundTint="#A5A8AA"
            android:stateListAnimator="@null"
            android:text="Batal"
            android:textColor="#F5F6F8"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="10dp" />

        <!-- Tombol Hapus -->
        <Button
            android:id="@+id/btnDialogHapus"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="Hapus"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#EF4444"
            app:cornerRadius="10dp"
            android:stateListAnimator="@null" />

    </LinearLayout>

</LinearLayout>
