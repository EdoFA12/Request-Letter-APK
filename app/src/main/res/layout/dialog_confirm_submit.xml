<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog"
    android:paddingHorizontal="24dp"
    android:paddingTop="28dp"
    android:paddingBottom="24dp">

    <!-- Icon -->
    <FrameLayout
        android:layout_width="68dp"
        android:layout_height="68dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_icon_circle_blue_light">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_document"
            app:tint="#1A3C8F"
            android:contentDescription="@null" />

    </FrameLayout>

    <!-- Judul -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="14dp"
        android:text="Konfirmasi Pengajuan"
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="#1A1A2E" />

    <!-- Subjudul -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="18dp"
        android:text="Pastikan data berikut sudah benar"
        android:textSize="12sp"
        android:textColor="#94A3B8"
        android:gravity="center" />

    <!-- Card ringkasan data -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_dialog_info_row"
        android:padding="14dp"
        android:layout_marginBottom="20dp">

        <!-- NIM -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="NIM"
                android:textSize="12sp"
                android:textColor="#94A3B8" />

            <TextView
                android:id="@+id/tvConfirmNim"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E" />

        </LinearLayout>

        <!-- Nama -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Nama"
                android:textSize="12sp"
                android:textColor="#94A3B8" />

            <TextView
                android:id="@+id/tvConfirmNama"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E" />

        </LinearLayout>

        <!-- Divider tipis -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F1F5F9"
            android:layout_marginBottom="10dp" />

        <!-- Kategori -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Kategori"
                android:textSize="12sp"
                android:textColor="#94A3B8" />

            <TextView
                android:id="@+id/tvConfirmKategori"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1A3C8F" />

        </LinearLayout>

        <!-- Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Status"
                android:textSize="12sp"
                android:textColor="#94A3B8" />

            <TextView
                android:id="@+id/tvConfirmStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E" />

        </LinearLayout>

        <!-- Divider tipis -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F1F5F9"
            android:layout_marginBottom="10dp" />

        <!-- Tanggal Mulai -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tgl. Mulai"
                android:textSize="12sp"
                android:textColor="#94A3B8" />

            <TextView
                android:id="@+id/tvConfirmTglMulai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E" />

        </LinearLayout>

        <!-- Tanggal Selesai -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tgl. Selesai"
                android:textSize="12sp"
                android:textColor="#94A3B8" />

            <TextView
                android:id="@+id/tvConfirmTglSelesai"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E" />

        </LinearLayout>

        <!-- Divider tipis -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#F1F5F9"
            android:layout_marginBottom="10dp" />

        <!-- Instansi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="top">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Instansi"
                android:textSize="12sp"
                android:textColor="#94A3B8" />

            <TextView
                android:id="@+id/tvConfirmInstansi"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.5"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:gravity="end" />

        </LinearLayout>

    </LinearLayout>

    <!-- Tombol aksi -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Tombol Periksa Lagi -->
        <Button
            android:id="@+id/btnDialogKembali"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:backgroundTint="#8230B6F5"
            android:stateListAnimator="@null"
            android:text="Periksa Lagi"
            android:textColor="#1A3C8F"
            android:textSize="13sp"
            android:textStyle="bold"
            app:cornerRadius="15dp" />

        <!-- Tombol Ya, Kirim -->
        <Button
            android:id="@+id/btnDialogKirim"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:backgroundTint="#1A3C8F"
            android:stateListAnimator="@null"
            android:text="Ya, Kirim!"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            app:cornerRadius="15dp" />

    </LinearLayout>

</LinearLayout>

