<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background gradient biru -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#0D2457"
                android:centerColor="#1A3C8F"
                android:endColor="#2952C8" />
        </shape>
    </item>

    <!-- Lingkaran dekoratif kanan atas -->
    <item
        android:top="-40dp"
        android:right="-40dp"
        android:bottom="56dp"
        android:left="56dp">
        <shape android:shape="oval">
            <solid android:color="#1AFFFFFF" />
        </shape>
    </item>

    <!-- Glassmorphism box -->
    <item
        android:top="18dp"
        android:left="18dp"
        android:right="18dp"
        android:bottom="18dp">
        <shape android:shape="rectangle">
            <solid android:color="#33FFFFFF" />
            <corners android:radius="10dp" />
        </shape>
    </item>

    <!-- Icon dokumen (foreground) -->
    <item
        android:top="20dp"
        android:left="20dp"
        android:right="20dp"
        android:bottom="20dp"
        android:drawable="@drawable/ic_launcher_foreground" />

</layer-list>

